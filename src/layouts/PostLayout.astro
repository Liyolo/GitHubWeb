---
import BaseLayout from "./BaseLayout.astro";
import TableOfContents from "../components/TableOfContents.astro";
import type { BlogPost } from "../lib/posts";

interface Props {
  title: string;
  description: string;
  slug: string;
  pubDate: Date;
  category: string;
  tags: string[];
  headings: { depth: number; slug: string; text: string }[];
  image?: string;
  previousPost?: BlogPost;
  nextPost?: BlogPost;
}

const { title, description, slug, pubDate, category, tags, headings, image, previousPost, nextPost } = Astro.props;
const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path = "") => `${baseUrl}${path.replace(/^\/+/, "")}`;
const resolveImageUrl = (imagePath?: string) => {
  if (!imagePath) return undefined;
  if (/^https?:\/\//i.test(imagePath)) return imagePath;

  const basePath = baseUrl.replace(/^\/+|\/+$/g, "");
  let imagePathWithBase = imagePath.replace(/^\/+/, "");

  if (basePath) {
    const duplicateBase = `${basePath}/${basePath}/`;
    while (imagePathWithBase.startsWith(duplicateBase)) {
      imagePathWithBase = imagePathWithBase.slice(basePath.length + 1);
    }

    if (imagePathWithBase !== basePath && !imagePathWithBase.startsWith(`${basePath}/`)) {
      imagePathWithBase = `${basePath}/${imagePathWithBase}`;
    }
  }

  return new URL(imagePathWithBase, Astro.site).toString();
};
const imageUrl = resolveImageUrl(image);
const formattedDate = new Intl.DateTimeFormat("zh-CN", {
  year: "numeric",
  month: "2-digit",
  day: "2-digit",
}).format(pubDate);
const structuredData = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: title,
  description,
  datePublished: pubDate.toISOString(),
  dateModified: pubDate.toISOString(),
  author: {
    "@type": "Person",
    name: "Notes & Fieldwork",
  },
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": new URL(withBase(`posts/${slug}/`), Astro.site).toString(),
  },
  keywords: tags.join(", "),
  ...(imageUrl ? { image: imageUrl } : {}),
};
---

<BaseLayout
  title={`${title} | Notes & Fieldwork`}
  description={description}
  image={image}
  type="article"
  structuredData={structuredData}
>
  <article class="post-page">
    <a class="back-link" href={withBase()}>← 返回首页</a>
    <p class="post-meta">{formattedDate} · {category}</p>
    <h1>{title}</h1>
    <p class="post-description">{description}</p>
    <div class="tag-list" aria-label="文章标签">
      {tags.map((tag) => <span>{tag}</span>)}
    </div>
    <div class="article-content">
      <TableOfContents headings={headings} />
      <slot />
    </div>
    <nav class="post-navigation" aria-label="上一篇和下一篇文章">
      {
        previousPost ? (
          <a class="post-navigation-card" href={withBase(`posts/${previousPost.slug}/`)}>
            <span>上一篇</span>
            <strong>{previousPost.data.title}</strong>
          </a>
        ) : (
          <div class="post-navigation-card disabled" aria-disabled="true">
            <span>上一篇</span>
            <strong>已经是最新文章</strong>
          </div>
        )
      }
      {
        nextPost ? (
          <a class="post-navigation-card" href={withBase(`posts/${nextPost.slug}/`)}>
            <span>下一篇</span>
            <strong>{nextPost.data.title}</strong>
          </a>
        ) : (
          <div class="post-navigation-card disabled" aria-disabled="true">
            <span>下一篇</span>
            <strong>已经是最后一篇</strong>
          </div>
        )
      }
    </nav>
  </article>
</BaseLayout>
