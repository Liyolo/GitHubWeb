---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import { categorySlug, getPublishedPosts, getTags, tagSlug, type BlogPost } from "../lib/posts";
import { getSiteSettings } from "../lib/settings";
import { formatDate, withBase } from "../lib/site";

const posts = getPublishedPosts(await getCollection("posts"));
const featured = posts.find((post) => post.data.featured) ?? posts[0];
const tags = getTags(posts).slice(0, 12);
const settings = await getSiteSettings();
const { contactLinks } = settings;
const resolveImagePath = (image?: string) => {
  if (!image) return undefined;
  if (/^https?:\/\//i.test(image)) return image;
  return withBase(image);
};
const normalizeSearchText = (value: string) => value.toLowerCase();
const searchIndex = posts.map((post: BlogPost) => ({
  slug: post.slug,
  title: post.data.title,
  description: post.data.description,
  category: post.data.category,
  tags: post.data.tags,
  url: withBase(`posts/${post.slug}/`),
  text: normalizeSearchText(
    [post.data.title, post.data.description, post.data.category, ...post.data.tags].join(" ")
  ),
}));
const searchIndexJson = JSON.stringify(searchIndex).replace(/</g, "\\u003c");
const structuredData = {
  "@context": "https://schema.org",
  "@type": "Blog",
  name: settings.site.name,
  description: settings.site.description,
  url: new URL(withBase(), Astro.site).toString(),
};
---

<BaseLayout structuredData={structuredData}>
  <section class="hero" aria-labelledby="hero-title">
    <div class="hero-media" role="img" aria-label="铺开的笔记、咖啡和晨光中的书桌"></div>
    <div class="hero-content">
      <p class="eyebrow">{settings.home.eyebrow}</p>
      <h1 id="hero-title">{settings.home.heroTitle}</h1>
      <p class="hero-copy">{settings.home.heroCopy}</p>
      <div class="hero-actions">
        <a class="button primary" href="#posts">阅读文章</a>
        <a class="button ghost" href="#about">认识我</a>
      </div>
    </div>
  </section>

  <section class="featured" aria-labelledby="featured-title">
    <div class="section-heading">
      <p class="eyebrow">Featured</p>
      <h2 id="featured-title">最近想写明白的事</h2>
    </div>
    {featured ? (
      <article class="feature-story">
        {featured.data.image && (
          <img
            class="feature-story-image"
            src={resolveImagePath(featured.data.image)}
            alt={`《${featured.data.title}》文章封面`}
            loading="eager"
          />
        )}
        <div>
          <p class="post-meta">{formatDate(featured.data.pubDate)} · {featured.data.category}</p>
          <h3><a href={withBase(`posts/${featured.slug}/`)}>{featured.data.title}</a></h3>
        </div>
        <p>{featured.data.description}</p>
      </article>
    ) : (
      <p class="empty-state">还没有发布文章。第一篇内容上线后会显示在这里。</p>
    )}
  </section>

  <section id="posts" class="posts-section" aria-labelledby="posts-title">
    <div class="section-heading">
      <p class="eyebrow">Journal</p>
      <h2 id="posts-title">文章</h2>
    </div>

    <div class="post-search" role="search">
      <label for="postSearch">搜索文章</label>
      <input
        id="postSearch"
        name="postSearch"
        type="search"
        placeholder="输入标题、摘要、分类或标签"
        autocomplete="off"
      />
      <p class="search-help">可以搜索标题、摘要、分类和标签。</p>
    </div>

    <div class="filter-bar" role="list" aria-label="文章筛选">
      <button class="filter active" data-filter="all" type="button" aria-pressed="true">全部</button>
      <button class="filter" data-filter="项目" type="button" aria-pressed="false">项目</button>
      <button class="filter" data-filter="学习" type="button" aria-pressed="false">学习</button>
      <button class="filter" data-filter="生活" type="button" aria-pressed="false">生活</button>
    </div>

    <p class="search-status" aria-live="polite">
      显示 <span data-search-count>{posts.length}</span> 篇文章
    </p>

    <div class="post-grid" id="postGrid">
      {posts.length > 0 ? (
        posts.map((post) => (
          <article class="post-card" data-topic={post.data.category} data-slug={post.slug}>
            {post.data.image && (
              <img
                class="post-card-image"
                src={resolveImagePath(post.data.image)}
                alt={`《${post.data.title}》文章封面`}
                loading="lazy"
              />
            )}
            <p class="post-meta">
              {formatDate(post.data.pubDate)} ·
              <a href={withBase(`categories/${categorySlug(post.data.category)}/`)}>{post.data.category}</a>
            </p>
            <h3><a href={withBase(`posts/${post.slug}/`)}>{post.data.title}</a></h3>
            <p>{post.data.description}</p>
            <div class="mini-tag-list">
              {post.data.tags.map((tag) => (
                <a href={withBase(`tags/${tagSlug(tag)}/`)}>{tag}</a>
              ))}
            </div>
            <a class="read-more" href={withBase(`posts/${post.slug}/`)}>阅读全文</a>
          </article>
        ))
      ) : (
        <p class="empty-state">暂无文章，稍后再来看看。</p>
      )}
    </div>

    <p class="empty-state search-empty" hidden>没有找到匹配的文章，换个关键词试试。</p>

    {tags.length > 0 && (
      <div class="topic-cloud" aria-label="热门标签">
        <p class="eyebrow">Tags</p>
        {tags.map((entry) => (
          <a href={withBase(`tags/${entry.slug}/`)}>{entry.name}</a>
        ))}
      </div>
    )}
  </section>

  <section id="about" class="about-section" aria-labelledby="about-title">
    <div class="about-copy">
      <p class="eyebrow">{settings.home.aboutEyebrow}</p>
      <h2 id="about-title">{settings.home.aboutTitle}</h2>
      <p>{settings.home.aboutCopy}</p>
    </div>
    <div class="about-panel" aria-label="博客主题">
      {settings.home.topics.map((topic) => <span>{topic}</span>)}
    </div>
  </section>

  <section id="contact" class="contact-section" aria-labelledby="contact-title">
    <p class="eyebrow">{settings.home.contactEyebrow}</p>
    <h2 id="contact-title">{settings.home.contactTitle}</h2>
    <div class="contact-links">
      {contactLinks.map((link) => (
        <a href={link.href} rel={link.href.startsWith("http") ? "noreferrer" : undefined}>
          {link.label}
        </a>
      ))}
    </div>
  </section>

  <script type="application/json" id="post-search-data" set:html={searchIndexJson} />
  <script src={withBase("scripts/post-search.js")} defer></script>
</BaseLayout>
